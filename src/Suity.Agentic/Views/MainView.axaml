<UserControl x:Class="Suity.Editor.Views.MainView"
             xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:views="using:Suity.Editor.Views"
             xmlns:ctrls="using:Suity.Editor.Controls"
             xmlns:vm="using:Suity.Editor.ViewModels"
             mc:Ignorable="d"
             d:DesignWidth="900" d:DesignHeight="450"
             x:CompileBindings="True" x:DataType="vm:MainWindowViewModel">
    
    <UserControl.Resources>
        <SolidColorBrush x:Key="ProjectTagBackground" Color="#30FFFFFF" />
        <SolidColorBrush x:Key="ProjectTagBorder" Color="#50000000" />
    </UserControl.Resources>


    <Grid RowDefinitions="Auto,*" Background="{x:Null}" DragDrop.AllowDrop="True">
        <Grid Grid.Row="0" 
              ColumnDefinitions="Auto,Auto,*,150" 
              Height="40" 
              Margin="16,4,8,0"
              Background="Transparent" 
              PointerPressed="TitleBar_OnPointerPressed"
              > 
            
            <Image Grid.Column="0"
                   Source="/Assets/suity-logo-gray.ico" 
                   Width="24" Height="24" 
                   Margin="0,0,8,0"  VerticalAlignment="Center"
                   IsHitTestVisible="False" />

            <Panel Grid.Column="1" VerticalAlignment="Center">
                <views:MenuView HorizontalAlignment="Left"/>
            </Panel>

            <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center" Margin="12,0,0,0">
                <Button Name="ProjectTitleButton"
                    Padding="8,2"
                    Background="{DynamicResource ProjectTagBackground}"
                    BorderBrush="{DynamicResource ProjectTagBorder}"
                    BorderThickness="1"
                    CornerRadius="4"
                    VerticalAlignment="Center">
        
                <TextBlock Name="ProjectTitle"
                           Text="" 
                           FontSize="12"
                           Foreground="{DynamicResource SystemControlForegroundBaseHighBrush}"/>
        
                <Button.Styles>
                    <Style Selector="Button:pointerover /template/ ContentPresenter#PART_ContentPresenter">
                        <Setter Property="Background" Value="#50FFFFFF" />
                    </Style>
                </Button.Styles>
                </Button>

                <Button x:Name="HomeButton"
                    Padding="8,2" Background="{DynamicResource ProjectTagBackground}"
                    BorderBrush="{DynamicResource ProjectTagBorder}"
                    BorderThickness="1"
                    CornerRadius="4"
                    VerticalAlignment="Center">

                    <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                        <PathIcon Data="M10,20V14H14V20H19V12H22L12,3L2,12H5V20H10Z"
                                  Width="12" Height="12"
                                  Foreground="{DynamicResource SystemControlForegroundBaseHighBrush}"/>

                        <TextBlock Text="Home"
                                   FontSize="12"
                                   Foreground="{DynamicResource SystemControlForegroundBaseHighBrush}"/>
                    </StackPanel>

                    <Button.Styles>
                        <Style Selector="Button:pointerover /template/ ContentPresenter#PART_ContentPresenter">
                            <Setter Property="Background" Value="#50FFFFFF" />
                        </Style>
                    </Button.Styles>
                </Button>

                <Button x:Name="SearchButton"
                    Padding="8,2" Background="{DynamicResource ProjectTagBackground}"
                    BorderBrush="{DynamicResource ProjectTagBorder}"
                    BorderThickness="1"
                    CornerRadius="4">
        
                    <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                        <PathIcon Data="M9.5,3A6.5,6.5 0 0,1 16,9.5C16,11.11 15.41,12.59 14.44,13.73L19.71,19L18.29,20.41L13.02,15.15C11.9,16.05 10.5,16.5 9.5,16.5A6.5,6.5 0 0,1 3,9.5A6.5,6.5 0 0,1 9.5,3M9.5,5A4.5,4.5 0 0,0 5,9.5A4.5,4.5 0 0,0 9.5,14A4.5,4.5 0 0,0 14,9.5A4.5,4.5 0 0,0 9.5,5Z" 
                                  Width="12" Height="12"
                                  Foreground="{DynamicResource SystemControlForegroundBaseHighBrush}"/>
            
                        <TextBlock Text="F3"
                                   FontSize="11" FontWeight="SemiBold"
                                   Foreground="{DynamicResource SystemControlForegroundBaseHighBrush}"
                                   Opacity="0.7"/> 
                    </StackPanel>
                </Button>
            </StackPanel>

            <Border Grid.Column="3" Width="100" IsHitTestVisible="False" />
        </Grid>

        <ctrls:EditorDockContainer Name="DockContainer" Margin="4" Grid.Row="1" />
    </Grid>
</UserControl>